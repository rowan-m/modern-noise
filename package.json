{
  "name": "modern-noise",
  "version": "1.0.0",
  "type": "module",
  "description": "A modern noise machine for a modern world.",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "dev": "serve public",
    "lint": "eslint public",
    "lint:sonar": "eslint public -c eslint.sonar.config.js",
    "lint:security": "eslint public -c eslint.security.config.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run format:check && npm run lint && npm run lint:sonar && npm run lint:security && npm run test"
  },
  "devDependencies": {
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "eslint": "^10.1.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "vitest": "^4.1.2"
  }
}
